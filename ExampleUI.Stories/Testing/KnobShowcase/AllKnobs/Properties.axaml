<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:ExampleUI.Stories.Testing.KnobShowcase.AllKnobs"
             x:Class="ExampleUI.Stories.Testing.KnobShowcase.AllKnobs.Properties"
             x:DataType="local:Story">
    <StackPanel Spacing="12" Margin="8">
        <StackPanel Spacing="4">
            <TextBlock Text="Heading" FontWeight="SemiBold" />
            <TextBox Text="{Binding Heading}" />
        </StackPanel>
        <StackPanel Spacing="4">
            <TextBlock Text="Description" FontWeight="SemiBold" />
            <TextBox Text="{Binding KnobDescription}" />
        </StackPanel>
        <StackPanel Spacing="4">
            <TextBlock Text="Highlighted" FontWeight="SemiBold" />
            <ToggleSwitch IsChecked="{Binding IsHighlighted}" />
        </StackPanel>
        <StackPanel Spacing="4">
            <TextBlock Text="Alignment" FontWeight="SemiBold" />
            <ComboBox x:Name="AlignmentComboBox" SelectedItem="{Binding Alignment}" />
        </StackPanel>
        <StackPanel Spacing="4">
            <TextBlock Text="Item Count" FontWeight="SemiBold" />
            <NumericUpDown Value="{Binding ItemCount}" Minimum="0" Maximum="10" Increment="1" />
        </StackPanel>
    </StackPanel>
</UserControl>
