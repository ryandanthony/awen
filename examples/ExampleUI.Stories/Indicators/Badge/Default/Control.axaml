<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:ExampleUI.Controls"
             xmlns:local="using:ExampleUI.Stories.Indicators.Badge.Default"
             x:Class="ExampleUI.Stories.Indicators.Badge.Default.Control"
             x:DataType="local:Story">
    <controls:Badge Text="{Binding Text}"
                    Variant="{Binding Variant}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
</UserControl>
