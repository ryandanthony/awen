<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:ExampleUI.Controls"
             xmlns:local="using:ExampleUI.Stories.Testing.KnobShowcase.AllKnobs"
             x:Class="ExampleUI.Stories.Testing.KnobShowcase.AllKnobs.Control"
             x:DataType="local:Story">
    <controls:KnobShowcase Heading="{Binding Heading}"
                           Description="{Binding KnobDescription}"
                           IsHighlighted="{Binding IsHighlighted}"
                           ContentAlignment="{Binding Alignment}"
                           ItemCount="{Binding ItemCount}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
</UserControl>
