<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Awen.ViewModels"
             x:Class="Awen.Views.PropertyPanel"
             x:DataType="vm:PropertyPanelViewModel"
             Background="{DynamicResource LightBackground}"
             Foreground="{DynamicResource LightText}">
    <Panel>
        <!-- Empty state: no story selected -->
        <TextBlock Text="Select a story to edit its properties"
                   Foreground="{DynamicResource LightTextTertiary}"
                   FontSize="11"
                   TextAlignment="Center"
                   Opacity="0.7"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   IsVisible="{Binding !HasStorySelected}" />

        <!-- Empty state: story selected but no properties -->
        <TextBlock Text="No properties"
                   Foreground="{DynamicResource LightTextTertiary}"
                   FontSize="13"
                   FontWeight="500"
                   TextAlignment="Center"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   IsVisible="{Binding IsEmpty}">
            <TextBlock.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Path="HasStorySelected" />
                    <Binding Path="IsEmpty" />
                    <Binding Path="!HasError" />
                </MultiBinding>
            </TextBlock.IsVisible>
        </TextBlock>

        <!-- Error state -->
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    IsVisible="{Binding HasError}">
            <TextBlock Text="⚠️ Error"
                       FontWeight="Bold"
                       Foreground="{DynamicResource ColorError}"
                       FontSize="13"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource LightTextSecondary}"
                       FontSize="11"
                       MaxWidth="280"
                       TextAlignment="Center" />
        </StackPanel>

        <!-- Story properties content -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding !IsEmpty}">
            <DockPanel>
                <!-- Section header -->
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource LightSurface}"
                        BorderBrush="{DynamicResource LightBorder}"
                        BorderThickness="0,0,0,1"
                        Padding="0,8">
                    <TextBlock Text="Properties"
                               Foreground="{DynamicResource LightText}"
                               FontSize="11"
                               FontWeight="Bold"
                               Opacity="0.6" />
                </Border>

                <!-- Rendered properties control from the story -->
                <ContentControl Content="{Binding PropertiesContent}"
                                Margin="0,8,0,0" />
            </DockPanel>
        </ScrollViewer>
    </Panel>
</UserControl>
