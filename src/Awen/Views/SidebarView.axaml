<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Awen.ViewModels"
             xmlns:converters="using:Awen.Converters"
             x:Class="Awen.Views.SidebarView"
             x:DataType="vm:SidebarViewModel"
             x:Name="SidebarControl">
    <UserControl.Resources>
        <converters:BooleanToBrushConverter x:Key="SelectionBrushConverter"
                                            FalseBrush="Transparent">
            <converters:BooleanToBrushConverter.TrueBrush>
                <SolidColorBrush Color="#E0E0E0" />
            </converters:BooleanToBrushConverter.TrueBrush>
        </converters:BooleanToBrushConverter>
    </UserControl.Resources>
    <UserControl.Styles>
        <!-- Override Expander toggle button styling for light theme -->
        <Style Selector="Expander /template/ ToggleButton#PART_toggle">
            <Setter Property="Background" Value="{DynamicResource LightSurfaceVariant}" />
            <Setter Property="Foreground" Value="{DynamicResource LightText}" />
        </Style>
        <Style Selector="Expander /template/ ToggleButton#PART_toggle:pointerover">
            <Setter Property="Background" Value="{DynamicResource LightBorder}" />
        </Style>
        <Style Selector="Expander /template/ PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource LightText}" />
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
        </Style>
        <Style Selector="Expander /template/ Border#ExpanderContent">
            <Setter Property="Background" Value="{DynamicResource LightBackground}" />
        </Style>
    </UserControl.Styles>
    <DockPanel Background="{DynamicResource LightBackground}">
        <!-- Filter text box at top -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource LightBackground}"
                BorderBrush="{DynamicResource LightBorder}"
                BorderThickness="0,0,0,1"
                Padding="0,0,0,8"
                Margin="0,0,0,8">
            <TextBox Text="{Binding FilterText, Mode=TwoWay}"
                     Watermark="🔍 Filter stories…"
                     Background="{DynamicResource LightSurface}"
                     Foreground="{DynamicResource LightText}"
                     BorderBrush="{DynamicResource LightBorder}"
                     BorderThickness="1"
                     Padding="8,6"
                     CornerRadius="4"
                     FontSize="12" />
        </Border>

        <!-- Empty state overlay -->
        <Panel>
            <TextBlock Text="No stories found."
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource LightTextTertiary}"
                       FontSize="12"
                       IsVisible="{Binding IsEmpty}" />

            <!-- Accordion sidebar -->
            <ScrollViewer IsVisible="{Binding !IsEmpty}"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding TreeNodes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:SidebarTreeNode">
                            <!-- Library-level expander -->
                            <Expander IsExpanded="{Binding IsExpanded}"
                                      IsVisible="{Binding IsVisible}"
                                      Margin="0,0,0,4"
                                      HorizontalAlignment="Stretch"
                                      Background="{DynamicResource LightSurfaceVariant}"
                                      BorderBrush="{DynamicResource LightBorder}"
                                      BorderThickness="1"
                                      Padding="8,4">
                                <Expander.Header>
                                    <TextBlock Text="{Binding Label}"
                                               FontWeight="Bold"
                                               FontSize="12"
                                               Foreground="{DynamicResource LightText}"
                                               Margin="0,0" />
                                </Expander.Header>
                                <ItemsControl ItemsSource="{Binding Children}"
                                              Margin="12,0,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:SidebarTreeNode">
                                            <!-- Group-level expander or story leaf -->
                                            <ContentControl Content="{Binding}"
                                                            IsVisible="{Binding IsVisible}">
                                                <ContentControl.ContentTemplate>
                                                    <DataTemplate DataType="vm:SidebarTreeNode">
                                                        <Panel>
                                                            <!-- Group node: nested expander -->
                                                            <Expander IsExpanded="{Binding IsExpanded}"
                                                                      IsVisible="{Binding IsGroup}"
                                                                      Margin="0,0,0,1"
                                                                      HorizontalAlignment="Stretch"
                                                                      Background="{DynamicResource LightSurfaceVariant}"
                                                                      BorderBrush="{DynamicResource LightBorder}"
                                                                      BorderThickness="1"
                                                                      Padding="8,4">
                                                                <Expander.Header>
                                                                    <TextBlock Text="{Binding Label}"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="12"
                                                                               Foreground="{DynamicResource LightText}"
                                                                               Margin="0,0" />
                                                                </Expander.Header>
                                                                <ItemsControl ItemsSource="{Binding Children}"
                                                                              Margin="12,0,0,0">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate DataType="vm:SidebarTreeNode">
                                                                            <Panel IsVisible="{Binding IsVisible}">
                                                                                <!-- Nested group -->
                                                                                <Expander IsExpanded="{Binding IsExpanded}"
                                                                                          IsVisible="{Binding IsGroup}"
                                                                                          Margin="0,0,0,1"
                                                                                          HorizontalAlignment="Stretch"
                                                                                          Background="{DynamicResource LightSurfaceVariant}"
                                                                                          BorderBrush="{DynamicResource LightBorder}"
                                                                                          BorderThickness="1"
                                                                                          Padding="8,4">
                                                                                    <Expander.Header>
                                                                                        <TextBlock Text="{Binding Label}"
                                                                                                   FontWeight="SemiBold"
                                                                                                   FontSize="12"
                                                                                                   Foreground="{DynamicResource LightText}"
                                                                                                   Margin="0,0" />
                                                                                    </Expander.Header>
                                                                                    <ItemsControl ItemsSource="{Binding Children}"
                                                                                                  Margin="12,0,0,0">
                                                                                        <ItemsControl.ItemTemplate>
                                                                                            <DataTemplate DataType="vm:SidebarTreeNode">
                                                                                                <!-- Deepest story leaf -->
                                                                                                <Button Content="{Binding Label}"
                                                                                                        Command="{Binding #SidebarControl.DataContext.SelectStoryCommand}"
                                                                                                        CommandParameter="{Binding Story}"
                                                                                                        IsVisible="{Binding IsVisible}"
                                                                                                        HorizontalAlignment="Stretch"
                                                                                                        HorizontalContentAlignment="Left"
                                                                                                        Padding="4,2"
                                                                                                        Margin="0,1"
                                                                                                        Background="{Binding IsSelected, Converter={StaticResource SelectionBrushConverter}}"
                                                                                                        Foreground="{DynamicResource LightText}"
                                                                                                        BorderBrush="Transparent"
                                                                                                        FontSize="12" />
                                                                                            </DataTemplate>
                                                                                        </ItemsControl.ItemTemplate>
                                                                                    </ItemsControl>
                                                                                </Expander>

                                                                                <!-- Story leaf at this level -->
                                                                                <Button Content="{Binding Label}"
                                                                                        Command="{Binding #SidebarControl.DataContext.SelectStoryCommand}"
                                                                                        CommandParameter="{Binding Story}"
                                                                                        IsVisible="{Binding !IsGroup}"
                                                                                        HorizontalAlignment="Stretch"
                                                                                        HorizontalContentAlignment="Left"
                                                                                        Padding="4,2"
                                                                                        Margin="0,1"
                                                                                        Background="{Binding IsSelected, Converter={StaticResource SelectionBrushConverter}}"
                                                                                        Foreground="{DynamicResource LightText}"
                                                                                        BorderBrush="Transparent"
                                                                                        FontSize="12" />
                                                                            </Panel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Expander>

                                                            <!-- Story leaf at group level -->
                                                            <Button Content="{Binding Label}"
                                                                    Command="{Binding #SidebarControl.DataContext.SelectStoryCommand}"
                                                                    CommandParameter="{Binding Story}"
                                                                    IsVisible="{Binding !IsGroup}"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Left"
                                                                    Padding="4,2"
                                                                    Margin="0,1"
                                                                    Background="{Binding IsSelected, Converter={StaticResource SelectionBrushConverter}}"
                                                                    Foreground="{DynamicResource LightText}"
                                                                    BorderBrush="Transparent"
                                                                    FontSize="12" />
                                                        </Panel>
                                                    </DataTemplate>
                                                </ContentControl.ContentTemplate>
                                            </ContentControl>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Panel>
    </DockPanel>
</UserControl>
