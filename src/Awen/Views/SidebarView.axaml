<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Awen.ViewModels"
             xmlns:converters="using:Awen.Converters"
             x:Class="Awen.Views.SidebarView"
             x:DataType="vm:SidebarViewModel"
             x:Name="SidebarControl">
    <UserControl.Resources>
        <converters:BooleanToBrushConverter x:Key="SelectionBrushConverter"
                                            FalseBrush="Transparent">
            <converters:BooleanToBrushConverter.TrueBrush>
                <SolidColorBrush Color="#E0E0E0" />
            </converters:BooleanToBrushConverter.TrueBrush>
        </converters:BooleanToBrushConverter>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="ToggleButton.sidebar-group-header">
            <Setter Property="Background" Value="{DynamicResource LightSurfaceVariant}" />
            <Setter Property="Foreground" Value="{DynamicResource LightText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LightBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Transitions" Value="{x:Null}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style Selector="ToggleButton.sidebar-group-header:pointerover">
            <Setter Property="Background" Value="{DynamicResource LightBorder}" />
        </Style>
        <Style Selector="ToggleButton.sidebar-group-header:checked">
            <Setter Property="Background" Value="#E8E8E8" />
        </Style>
        <Style Selector="ToggleButton.sidebar-group-header.library">
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style Selector="ToggleButton.sidebar-group-header.group">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Border.sidebar-children-container">
            <Setter Property="Margin" Value="10,0,0,0" />
        </Style>
        <Style Selector="Button.sidebar-story-item">
            <Setter Property="Transitions" Value="{x:Null}" />
        </Style>
    </UserControl.Styles>
    <DockPanel Background="{DynamicResource LightBackground}">
        <!-- Filter text box at top -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource LightBackground}"
                BorderBrush="{DynamicResource LightBorder}"
                BorderThickness="0,0,0,1"
                Padding="0,0,0,6"
                Margin="0,0,0,6">
            <TextBox Text="{Binding FilterText, Mode=TwoWay}"
                     Watermark="🔍 Filter stories…"
                     Background="{DynamicResource LightSurface}"
                     Foreground="{DynamicResource LightText}"
                     BorderBrush="{DynamicResource LightBorder}"
                     BorderThickness="1"
                     Padding="6,4"
                     CornerRadius="4"
                     FontSize="14" />
        </Border>

        <!-- Empty state overlay -->
        <Panel>
            <TextBlock Text="No stories found."
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource LightTextTertiary}"
                       FontSize="16"
                       IsVisible="{Binding IsEmpty}" />

            <!-- Accordion sidebar -->
            <ScrollViewer IsVisible="{Binding !IsEmpty}"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding TreeNodes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:SidebarTreeNode">
                            <StackPanel IsVisible="{Binding IsVisible}">
                                <ToggleButton Content="{Binding Label}"
                                              Classes="sidebar-group-header library"
                                              IsChecked="{Binding IsExpanded}"
                                              Margin="0,0,0,2" />
                                <Border Classes="sidebar-children-container"
                                        IsVisible="{Binding IsExpanded}">
                                    <ItemsControl ItemsSource="{Binding Children}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:SidebarTreeNode">
                                                <ContentControl Content="{Binding}"
                                                                IsVisible="{Binding IsVisible}">
                                                    <ContentControl.ContentTemplate>
                                                        <DataTemplate DataType="vm:SidebarTreeNode">
                                                            <StackPanel>
                                                                <ToggleButton Content="{Binding Label}"
                                                                              Classes="sidebar-group-header group"
                                                                              IsChecked="{Binding IsExpanded}"
                                                                              IsVisible="{Binding IsGroup}"
                                                                              Margin="0,0,0,1" />
                                                                <Border Classes="sidebar-children-container"
                                                                        IsVisible="{Binding IsGroup}">
                                                                    <ItemsControl ItemsSource="{Binding Children}"
                                                                                  IsVisible="{Binding IsExpanded}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate DataType="vm:SidebarTreeNode">
                                                                                <StackPanel IsVisible="{Binding IsVisible}">
                                                                                    <ToggleButton Content="{Binding Label}"
                                                                                                  Classes="sidebar-group-header group"
                                                                                                  IsChecked="{Binding IsExpanded}"
                                                                                                  IsVisible="{Binding IsGroup}"
                                                                                                  Margin="0,0,0,1" />
                                                                                    <Border Classes="sidebar-children-container"
                                                                                            IsVisible="{Binding IsGroup}">
                                                                                        <ItemsControl ItemsSource="{Binding Children}"
                                                                                                      IsVisible="{Binding IsExpanded}">
                                                                                            <ItemsControl.ItemTemplate>
                                                                                                <DataTemplate DataType="vm:SidebarTreeNode">
                                                                                                    <Button Content="{Binding Label}"
                                                                                                            Classes="sidebar-story-item"
                                                                                                            Command="{Binding #SidebarControl.DataContext.SelectStoryCommand}"
                                                                                                            CommandParameter="{Binding Story}"
                                                                                                            IsVisible="{Binding IsVisible}"
                                                                                                            HorizontalAlignment="Stretch"
                                                                                                            HorizontalContentAlignment="Left"
                                                                                                            Padding="4,1"
                                                                                                            Margin="0,0"
                                                                                                            Background="{Binding IsSelected, Converter={StaticResource SelectionBrushConverter}}"
                                                                                                            Foreground="{DynamicResource LightText}"
                                                                                                            BorderBrush="Transparent"
                                                                                                            FontSize="14" />
                                                                                                </DataTemplate>
                                                                                            </ItemsControl.ItemTemplate>
                                                                                        </ItemsControl>
                                                                                    </Border>

                                                                                    <Button Content="{Binding Label}"
                                                                                            Classes="sidebar-story-item"
                                                                                            Command="{Binding #SidebarControl.DataContext.SelectStoryCommand}"
                                                                                            CommandParameter="{Binding Story}"
                                                                                            IsVisible="{Binding !IsGroup}"
                                                                                            HorizontalAlignment="Stretch"
                                                                                            HorizontalContentAlignment="Left"
                                                                                            Padding="4,1"
                                                                                            Margin="0,0"
                                                                                            Background="{Binding IsSelected, Converter={StaticResource SelectionBrushConverter}}"
                                                                                            Foreground="{DynamicResource LightText}"
                                                                                            BorderBrush="Transparent"
                                                                                            FontSize="14" />
                                                                                </StackPanel>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </Border>

                                                                <Button Content="{Binding Label}"
                                                                    Classes="sidebar-story-item"
                                                                        Command="{Binding #SidebarControl.DataContext.SelectStoryCommand}"
                                                                        CommandParameter="{Binding Story}"
                                                                        IsVisible="{Binding !IsGroup}"
                                                                        HorizontalAlignment="Stretch"
                                                                        HorizontalContentAlignment="Left"
                                                                        Padding="4,1"
                                                                        Margin="0,0"
                                                                        Background="{Binding IsSelected, Converter={StaticResource SelectionBrushConverter}}"
                                                                        Foreground="{DynamicResource LightText}"
                                                                        BorderBrush="Transparent"
                                                                        FontSize="14" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ContentControl.ContentTemplate>
                                                </ContentControl>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Panel>
    </DockPanel>
</UserControl>
